{
  "name": "vetmcp",
  "version": "0.1.0",
  "description": "Security scanner for MCP servers — npm audit for the Model Context Protocol",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "audit",
    "prompt-injection",
    "tool-poisoning",
    "cli"
  ],
  "license": "MIT",
  "author": "Chri2K02 <ckearns2002@gmail.com>",
  "homepage": "https://github.com/vetmcp/vetmcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vetmcp/vetmcp.git"
  },
  "bugs": {
    "url": "https://github.com/vetmcp/vetmcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "vetmcp": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src fixtures",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
